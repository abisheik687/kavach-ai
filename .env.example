# KAVACH-AI — Environment Configuration
# Copy this file to .env and fill in the values.
# NO API KEYS required. All processing is local.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=KAVACH-AI
APP_VERSION=2.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── Trained artifact manifests ─────────────────────────────────────────────────
# After running: python training/train_all.py
# Set these to the metadata.json paths printed in the training summary.
# Example:
#   MODEL_IMAGE_ARTIFACT_MANIFEST=training/artifacts/image/efficientnet_b4_1234567890/metadata.json
#   MODEL_AUDIO_ARTIFACT_MANIFEST=training/artifacts/audio/audio_spectrogram_efficientnet_b0_1234567890/metadata.json
#   MODEL_VIDEO_ARTIFACT_MANIFEST=training/artifacts/video/r3d_18_1234567890/metadata.json
MODEL_IMAGE_ARTIFACT_MANIFEST=
MODEL_AUDIO_ARTIFACT_MANIFEST=
MODEL_VIDEO_ARTIFACT_MANIFEST=

# ── Model control ──────────────────────────────────────────────────────────────
# Set to false (default) to enforce trained-artifact-only mode.
# Set to true only for development without trained models.
ALLOW_FALLBACK_MODELS=false
ENABLE_REMOTE_MODEL_DOWNLOADS=false

# ── Timeouts (seconds) ─────────────────────────────────────────────────────────
IMAGE_TIMEOUT_SECONDS=30
AUDIO_TIMEOUT_SECONDS=45
VIDEO_TIMEOUT_SECONDS=120
ANALYSIS_TIMEOUT_SECONDS=120

# ── File size limits ───────────────────────────────────────────────────────────
MAX_IMAGE_AUDIO_BYTES=20971520
MAX_VIDEO_BYTES=104857600

# ── ffmpeg (leave blank to auto-detect from PATH) ─────────────────────────────
FFMPEG_BINARY=

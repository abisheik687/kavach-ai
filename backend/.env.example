# Internal trace:
# - Wrong before: the backend had no colocated env template even though config.py resolves .env from the backend working directory.
# - Fixed now: this backend example documents every active FastAPI/model setting used by the rebuilt upload pipeline.

APP_NAME=KAVACH-AI
APP_VERSION=2.0.0
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173","http://127.0.0.1:4173"]
MODEL_CACHE_DIR=../temp/model-cache
TEMP_DIR=../temp
MAX_IMAGE_AUDIO_BYTES=20971520
MAX_VIDEO_BYTES=104857600
MAX_IMAGE_PIXELS=1638400
MAX_VIDEO_FRAMES=30
MAX_VIDEO_PREVIEWS=6
VIDEO_FRAME_STRIDE=10
MAX_VIDEO_SECONDS=45
MAX_AUDIO_SECONDS=30
IMAGE_TIMEOUT_SECONDS=30
AUDIO_TIMEOUT_SECONDS=45
VIDEO_TIMEOUT_SECONDS=120
ANALYSIS_TIMEOUT_SECONDS=120
MAX_CONCURRENT_ANALYSES=2
ALLOW_FALLBACK_MODELS=false
ENABLE_REMOTE_MODEL_DOWNLOADS=false
DEFAULT_IMAGE_THRESHOLD=0.52
DEFAULT_AUDIO_THRESHOLD=0.52
DISAGREEMENT_THRESHOLD=0.4
MODEL_VIT_REPO=prithivMLmods/Deep-Fake-Detector-Model
MODEL_EFFICIENTNET_REPO=Wvolf/EfficientNet_Deepfake
MODEL_XCEPTION_REPO=not-lain/xception-deepfake
MODEL_CONVNEXT_REPO=facebook/convnext-base-224
MODEL_AUDIO_REPO=mo-thecreator/deepfake-audio-detector
MODEL_VIDEO_REPO=muneeb1812/videomae-base-fake-video-classification
MODEL_VIDEO_LOCAL_PATH=
MODEL_IMAGE_ARTIFACT_MANIFEST=
MODEL_AUDIO_ARTIFACT_MANIFEST=
MODEL_VIDEO_ARTIFACT_MANIFEST=
FFMPEG_BINARY=
